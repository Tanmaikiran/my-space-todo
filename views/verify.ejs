<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify OTP</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;400;500&display=swap" rel="stylesheet">
    <style>
        body { background: #0f0f0f; color: white; font-family: 'Outfit', sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; }
        .box { background: rgba(255,255,255,0.1); padding: 40px; border-radius: 20px; text-align: center; border: 1px solid rgba(255,255,255,0.1); }
        input { background: transparent; border: 1px solid #444; color: white; padding: 10px; margin: 10px 0; border-radius: 5px; width: 100%; text-align: center; }
        button { background: #a18cd1; border: none; padding: 10px 20px; border-radius: 5px; color: white; cursor: pointer; width: 100%; margin-top: 10px; }
    </style>
</head>
<body>
    <div class="box">
        <h2>Verify OTP</h2>
        <p>Sent to: <%= email %></p>
        <form action="/verify" method="POST">
            <input type="text" name="otp" placeholder="Enter 4-digit OTP" required maxlength="4">
            <button type="submit">Verify & Sign Up</button>
        </form>
    </div>
</body>
</html>