<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Space</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Outfit', sans-serif; }
        body { background: url('https://images.unsplash.com/photo-1519681393784-d120267933ba?q=80&w=2070&auto=format&fit=crop') no-repeat center center/cover; min-height: 100vh; display: flex; justify-content: center; padding-top: 80px; }
        body::before { content: ''; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.4); z-index: -1; }
        .app-container { background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(30px); width: 90%; max-width: 500px; border-radius: 40px; padding: 40px; box-shadow: 0 25px 50px rgba(0,0,0,0.3); border: 1px solid rgba(255, 255, 255, 0.2); color: white; }
        .input-group { display: flex; background: rgba(255, 255, 255, 0.15); border-radius: 50px; padding: 8px; border: 1px solid rgba(255, 255, 255, 0.3); margin-bottom: 30px; }
        input { flex-grow: 1; padding: 12px 20px; border: none; background: transparent; color: white; outline: none; }
        .add-btn { background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%); border: none; width: 45px; height: 45px; border-radius: 50%; color: white; cursor: pointer; }
        .task-item { display: flex; align-items: center; justify-content: space-between; background: rgba(0, 0, 0, 0.2); padding: 15px 20px; border-radius: 20px; margin-bottom: 12px; }
        .completed .task-text { text-decoration: line-through; opacity: 0.5; }
        .custom-checkbox { width: 22px; height: 22px; border: 2px solid rgba(255, 255, 255, 0.4); border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; }
        .completed .custom-checkbox { background: white; color: black; }
    </style>
</head>
<body>
    <div class="app-container">
        <h2>My Space</h2>
        <div class="input-group">
            <input type="text" id="todoInput" placeholder="Add task...">
            <button onclick="addTask()" class="add-btn"><i class="fas fa-plus"></i></button>
        </div>
        <ul class="task-list" id="taskList">
            <% todoTasks.forEach(task => { %>
                <li class="task-item <%= task.isCompleted ? 'completed' : '' %>" id="task-<%= task._id %>">
                    <span style="display:flex; align-items:center; gap:15px;">
                        <div class="custom-checkbox" onclick="toggleTask('<%= task._id %>')">
                            <% if(task.isCompleted) { %> <i class="fas fa-check"></i> <% } %>
                        </div>
                        <span class="task-text"><%= task.text %></span>
                    </span>
                    <button onclick="deleteTask('<%= task._id %>')" style="background:none; border:none; color:#ff6b6b; cursor:pointer;"><i class="fas fa-trash"></i></button>
                </li>
            <% }) %>
        </ul>
    </div>

    <script>
        const isPremium = <%= isPremium %>;

        async function addTask() {
            const list = document.getElementById('taskList');
            const val = document.getElementById('todoInput').value;
            
            // Hard Frontend Limit
            if (!isPremium && list.children.length >= 3) {
                alert("Limit Reached!");
                return buyPremium();
            }

            const res = await fetch('/add', { 
                method: 'POST', 
                headers: {'Content-Type': 'application/json'}, 
                body: JSON.stringify({newtodo: val}) 
            });
            const data = await res.json();
            if (data.error === 'limit') return buyPremium();
            location.reload();
        }

        async function buyPremium() {
            const res = await fetch('/api/payment/order', { method: 'POST' });
            const order = await res.json();
            const options = {
                "key": "rzp_test_SfFpmxjEKf5E9Z",
                "amount": order.amount,
                "order_id": order.id,
                "handler": async function() {
                    await fetch('/api/payment/success', { method: 'POST' });
                    location.reload();
                }
            };
            new Razorpay(options).open();
        }

        async function toggleTask(id) { await fetch(`/toggle/${id}`, { method: 'POST' }); location.reload(); }
        async function deleteTask(id) { await fetch('/delete', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({id}) }); location.reload(); }
    </script>
</body>
</html>