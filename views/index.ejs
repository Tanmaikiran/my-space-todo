<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Enterprise Workspace - Battu Tanmai Kiran</title>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <style>
        body { 
            font-family: 'Segoe UI', Tahoma, sans-serif; 
            background: #0f172a url('https://images.unsplash.com/photo-1519681393784-d120267933ba?auto=format&fit=crop&w=1920&q=80') center/cover fixed;
            color: white;
            display: flex; justify-content: center; align-items: center;
            min-height: 100vh; margin: 0;
        }
        .glass-card { 
            background: rgba(15, 23, 42, 0.6); 
            backdrop-filter: blur(12px); 
            -webkit-backdrop-filter: blur(12px);
            padding: 40px; border-radius: 20px; 
            width: 100%; max-width: 380px; text-align: center;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        /* The Slider Bar UI */
        .toggle-box {
            display: flex;
            background: rgba(255,255,255,0.1);
            border-radius: 25px;
            margin-bottom: 25px;
            padding: 4px;
        }
        .toggle-btn {
            flex: 1; padding: 10px; border: none; background: transparent; 
            color: rgba(255,255,255,0.7); cursor: pointer; border-radius: 20px; 
            transition: 0.3s; font-size: 14px; font-weight: bold;
        }
        .toggle-btn.active {
            background: #3399cc; color: white; box-shadow: 0 2px 10px rgba(51,153,204,0.4);
        }

        h2 { margin-top: 0; font-weight: 600; font-size: 26px; }
        input { 
            width: 100%; padding: 14px; margin: 8px 0; 
            background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); 
            border-radius: 10px; color: white; box-sizing: border-box;
            font-size: 14px;
        }
        input::placeholder { color: rgba(255,255,255,0.6); }
        input:focus { outline: none; background: rgba(255,255,255,0.2); border-color: rgba(255,255,255,0.5); }
        
        .btn-main { 
            width: 100%; padding: 14px; background: white; color: #0f172a; 
            border: none; border-radius: 10px; cursor: pointer; font-weight: bold; 
            margin-top: 15px; font-size: 15px; transition: 0.2s;
        }
        .btn-main:hover { background: #e0e0e0; transform: translateY(-2px); }
        .hidden { display: none; }
        
        .todo-item { display: flex; justify-content: space-between; padding: 12px; border-bottom: 1px solid rgba(255,255,255,0.1); text-align: left; align-items: center;}
        .del-btn { background: rgba(255,77,77,0.2); color: #ff4d4d; border: 1px solid #ff4d4d; padding: 6px 12px; border-radius: 15px; cursor: pointer; font-size: 12px;}
        .premium-btn { background: #3399cc; color: white; border: none; padding: 14px; border-radius: 10px; width: 100%; cursor: pointer; margin-top: 25px; font-weight: bold; font-size: 15px; box-shadow: 0 4px 15px rgba(51,153,204,0.4); }
    </style>
</head>
<body>
    <div class="glass-card">
        
        <div id="auth-ui">
            <h2>Workspace Auth</h2>
            
            <div class="toggle-box">
                <button id="tab-login" class="toggle-btn active" onclick="switchTab('login')">Login</button>
                <button id="tab-qr" class="toggle-btn" onclick="switchTab('qr')">Get QR Code</button>
            </div>
            
            <input type="text" id="user" placeholder="Email Address">
            <input type="password" id="pass" placeholder="Password">
            
            <div id="login-section">
                <input type="text" id="mfa" placeholder="6-Digit Code (From App)">
                <button class="btn-main" onclick="login()">Access Workspace</button>
            </div>

            <div id="qr-section" class="hidden">
                <button class="btn-main" onclick="register()" style="background: #3399cc; color: white;">Generate QR Code</button>
                
                <div id="qr-container" class="hidden" style="margin-top: 20px;">
                    <div style="background: white; padding: 10px; border-radius: 10px; display: inline-block;">
                        <img id="qr-image" src="" style="width:160px; display: block;">
                    </div>
                    <p style="margin-top: 10px; font-size: 13px; font-weight: bold;">1. Scan in Google Authenticator<br>2. Switch to 'Login' tab to enter code</p>
                </div>
            </div>
        </div>

        <div id="app-ui" class="hidden">
            <h2>My Tasks</h2>
            <input type="text" id="task" placeholder="Add a new task...">
            <button class="btn-main" onclick="addTask()">Add Task</button>
            
            <div id="list" style="margin-top: 20px; max-height: 200px; overflow-y: auto;"></div>
            
            <button class="premium-btn" onclick="buyPremium()">Buy Premium Now (₹499)</button>
            <div onclick="logout()" style="margin-top: 20px; cursor: pointer; font-size: 13px; color: rgba(255,255,255,0.7);">Logout</div>
        </div>
    </div>

    <script>
        let token = localStorage.getItem('token');
        if (token) showApp();

        // Slide Bar Logic
        function switchTab(tab) {
            document.getElementById('mfa').value = '';
            document.getElementById('qr-container').classList.add('hidden');
            
            if (tab === 'login') {
                document.getElementById('tab-login').classList.add('active');
                document.getElementById('tab-qr').classList.remove('active');
                document.getElementById('login-section').classList.remove('hidden');
                document.getElementById('qr-section').classList.add('hidden');
            } else {
                document.getElementById('tab-qr').classList.add('active');
                document.getElementById('tab-login').classList.remove('active');
                document.getElementById('qr-section').classList.remove('hidden');
                document.getElementById('login-section').classList.add('hidden');
            }
        }

        async function register() {
            if(!user.value || !pass.value) return alert("Enter email and password first.");

            const res = await fetch('/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username: user.value, password: pass.value })
            });
            const data = await res.json();
            
            if (data.qrCode) {
                document.getElementById('qr-container').classList.remove('hidden');
                document.getElementById('qr-image').src = data.qrCode;
            } else {
                alert("Error generating QR.");
            }
        }

        async function login() {
            if(!user.value || !pass.value || !mfa.value) return alert("Please fill in Email, Password, and the 6-Digit Code.");

            const res = await fetch('/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username: user.value, password: pass.value, mfaToken: mfa.value })
            });
            const data = await res.json();
            if (data.token) {
                localStorage.setItem('token', data.token);
                token = data.token;
                showApp();
            } else { 
                alert(data.error || "Login Failed"); 
            }
        }

        async function showApp() {
            document.getElementById('auth-ui').classList.add('hidden');
            document.getElementById('app-ui').classList.remove('hidden');
            const res = await fetch('/todos', { headers: { 'Authorization': `Bearer ${token}` }});
            const todos = await res.json();
            const listDiv = document.getElementById('list');
            listDiv.innerHTML = '';
            todos.forEach(t => {
                listDiv.innerHTML += `<div class="todo-item"><span>${t.text}</span><button class="del-btn" onclick="delTask('${t._id}')">Remove</button></div>`;
            });
        }

        async function addTask() {
            if(!task.value) return;
            await fetch('/todos', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify({ text: task.value })
            });
            task.value = '';
            showApp();
        }

        async function delTask(id) {
            await fetch(`/todos/${id}`, { method: 'DELETE', headers: { 'Authorization': `Bearer ${token}` }});
            showApp();
        }

        async function buyPremium() {
            try {
                const response = await fetch('/api/payment/order', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` }
                });
                const orderData = await response.json();

                const options = {
                    "key": "rzp_test_SfFpmxjEKf5E9Z", 
                    "amount": orderData.amount,
                    "currency": "INR",
                    "name": "My Workspace",
                    "description": "Premium Upgrade",
                    "order_id": orderData.id, 
                    "handler": function (response){
                        alert("Payment Successful! Welcome to Premium.");
                    },
                    "theme": { "color": "#3399cc" }
                };
                const rzp1 = new Razorpay(options);
                rzp1.open();
            } catch (error) {
                alert("Payment initiation failed.");
            }
        }

        function logout() { localStorage.removeItem('token'); location.reload(); }
    </script>
</body>
</html>