<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
    async function addTask() {
        const input = document.getElementById('todoInput');
        const res = await fetch('/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ newtodo: input.value })
        });
        
        if (res.status === 403) {
            return buyPremium();
        }
        location.reload();
    }

    async function buyPremium() {
        try {
            const res = await fetch('/api/payment/order', { method: 'POST' });
            const order = await res.json();

            const options = {
                "key": "rzp_test_SfFpmxjEKf5E9Z",
                "amount": order.amount,
                "currency": "INR",
                "name": "My Space Premium",
                "order_id": order.id,
                "handler": async function (response) {
                    await fetch('/api/payment/success', { method: 'POST' });
                    alert("Payment Successful! Refreshing...");
                    location.reload();
                },
                "theme": { "color": "#a18cd1" }
            };

            const rzp = new Razorpay(options);
            rzp.on('payment.failed', function (resp) { alert("Payment Failed"); });
            rzp.open();
        } catch (err) {
            console.error(err);
            alert("Error initializing Razorpay. Check console.");
        }
    }

    async function toggleTask(id) { await fetch(`/toggle/${id}`, { method: 'POST' }); location.reload(); }
    async function deleteTask(id) { await fetch('/delete', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({id}) }); location.reload(); }
</script>